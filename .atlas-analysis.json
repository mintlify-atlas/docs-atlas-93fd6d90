  "keyFeatures": [
    "Voice-activated command recognition using Google Speech Recognition",
    "Text-to-speech responses via pyttsx3",
    "Open popular websites by voice (Google, YouTube, Wikipedia, Amazon, GitHub)",
    "Web search via configurable search engine (Google, Bing, DuckDuckGo, YouTube)",
    "Wikipedia lookups with spoken summaries",
    "Send emails via SMTP using voice dictation",
    "Music playback control (play, pause, unpause, stop) via pygame",
    "Adjustable voice settings: gender, speech rate, volume",
    "Tkinter GUI with chat-style response display",
    "Cross-platform support: Windows and Ubuntu",
    "Debug mode with text input instead of microphone",
    "Configurable via config.ini file"
  ],
  "publicApiSurface": [
    "command_wikipedia(debug, query)",
    "command_whatsup()",
    "command_open(query, popular_websites, debug, search_engine, take_command)",
